# Solana RPC endpoint.
# Use a dedicated provider (QuickNode, Helius, Alchemy) for production.
# Falls back to the public mainnet-beta endpoint if omitted (heavily rate-limited).
VITE_SOLANA_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/YOUR_TOKEN/

# Base URL for the proxy API server used to forward CoinGecko / Jupiter requests.
# Defaults to https://api.eitherway.ai if omitted.
VITE_API_BASE_URL=https://api.eitherway.ai
